# =============================================================
# Chat-Bot configuration
# Copy to .env and fill in real values
#
# For local dev:   APP_DATABASE_URL points to localhost
# For production:  POSTGRES_* vars are used by docker-compose.prod.yml
#                  APP_DATABASE_URL is constructed automatically from them
# =============================================================

# ---- Telegram -----------------------------------------------
TG_BOT_TOKEN=your_bot_token_here
TG_ENABLED=true
TG_ADMIN_ID=
TG_PROMO_CHANNEL_USERNAME=
TG_PROMO_CHANNEL_LINK=
TG_SUPPORT_LINK=
TG_WELCOME_PROMO_CODE=WELCOME

# Promo code issued when user leaves their email (leave blank to disable)
APP_EMAIL_PROMO_CODE=EMAILBONUS10

# ---- MAX ----------------------------------------------------
MAX_BOT_TOKEN=your_max_token_here
MAX_ENABLED=false
MAX_ADMIN_ID=
MAX_CHANNEL_ID=
MAX_CHANNEL_LINK=
MAX_SUPPORT_LINK=
MAX_USE_WEBHOOK=false
MAX_WEBHOOK_URL=

# ---- Chatwoot (optional CRM) --------------------------------
CHATWOOT_ENABLED=false
# Use HTTPS in production!
CHATWOOT_BASE_URL=https://chatwoot.your-domain.com
CHATWOOT_API_TOKEN=
CHATWOOT_ACCOUNT_ID=1
CHATWOOT_INBOX_ID=1
# Required when CHATWOOT_ENABLED=true
CHATWOOT_WEBHOOK_SECRET=

# ---- Database (local dev) -----------------------------------
APP_DATABASE_URL=jdbc:postgresql://localhost:5432/chatbot_db?user=chatbot&password=CHANGE_ME_STRONG_PASSWORD

# ---- Database (Docker Compose production) -------------------
# These vars are used by docker-compose.prod.yml.
# APP_DATABASE_URL is constructed automatically from them — no need to set it manually.
POSTGRES_USER=chatbot
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=chatbot_db

# ---- Docker image (production) ------------------------------
DOCKER_IMAGE=ghcr.io/repiska/hexobot:latest

# ---- App ----------------------------------------------------
APP_PORT=3000
APP_HOST=0.0.0.0
# Echo mode: replies with the raw message (for testing only)
APP_ECHO_MODE=false
