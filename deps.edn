{:paths ["src" "resources"]

 :deps
 {;; HTTP Server & Client
  http-kit/http-kit {:mvn/version "2.7.0"}

  ;; Routing
  compojure/compojure {:mvn/version "1.7.1"}
  ring/ring-json {:mvn/version "0.5.1"}

  ;; Database
  com.github.seancorfield/next.jdbc {:mvn/version "1.3.909"}
  com.github.seancorfield/honeysql {:mvn/version "2.6.1126"}
  org.postgresql/postgresql {:mvn/version "42.7.1"}
  com.zaxxer/HikariCP {:mvn/version "5.1.0"}

  ;; Validation
  metosin/malli {:mvn/version "0.14.0"}

  ;; JSON
  cheshire/cheshire {:mvn/version "5.12.0"}

  ;; Environment
  environ/environ {:mvn/version "1.2.0"}

  ;; Logging
  org.clojure/tools.logging {:mvn/version "1.3.0"}
  ch.qos.logback/logback-classic {:mvn/version "1.4.14"}}

 :aliases
 {:dev {:extra-paths ["dev"]
        :extra-deps {nrepl/nrepl {:mvn/version "1.1.0"}}}

  :nrepl {:extra-deps {nrepl/nrepl {:mvn/version "1.1.0"}}
          :main-opts ["-m" "nrepl.cmdline" "--port" "7888"]}

  :run {:main-opts ["-m" "chatbot.core"]}

  :test {:extra-paths ["test"]
         :extra-deps {lambdaisland/kaocha {:mvn/version "1.87.1366"}}}

  ;; MCP Server для Claude Code интеграции
  :mcp {:extra-deps {org.hugoduncan/mcp-clj
                     {:git/url "https://github.com/hugoduncan/mcp-clj"
                      :git/sha "189f8c5abcd692ace48529a72f353647b7782db0"
                      :deps/root "projects/server"}}
        :main-opts ["-m" "mcp-clj.stdio-server.main"]}

  :build {:deps {io.github.clojure/tools.build {:git/tag "v0.9.6"
                                                 :git/sha "8e78bcc"}}
          :ns-default build}}}
